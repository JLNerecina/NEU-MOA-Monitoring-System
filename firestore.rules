rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, must be @neu.edu.ph)
    //   - role: string (required, student|faculty|admin)
    //   - displayName: string
    //   - photoURL: string
    //   - isBlocked: bool (optional)
    //   - college: string (optional)
    //
    // Collection: moas
    // Fields:
    //   - HTEID: string
    //   - Company: string
    //   - Address: string
    //   - ContactPerson: string
    //   - Email: string
    //   - IndustryType: string
    //   - EffectivityDate: string
    //   - Status: string
    //   - college: string
    //   - isDeleted: bool
    //   - auditTrail: list
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBlocked() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == role;
    }

    function isAdmin() {
      return request.auth != null && (
        (request.auth.token.get('email', '') == "johnliannerecina@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin') ||
        (request.auth.token.get('email', '') != '' && 
         exists(/databases/$(database)/documents/pre_authorized_roles/$(request.auth.token.email)) && 
         get(/databases/$(database)/documents/pre_authorized_roles/$(request.auth.token.email)).data.get('role', '') == 'admin')
      );
    }

    function isFaculty() {
      return isAdmin() || hasRole('faculty');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             (data.email.matches(".*@neu\\.edu\\.ph$") || data.email == "johnliannerecina@gmail.com") &&
             data.role in ['student', 'faculty', 'admin'] &&
             (!('isBlocked' in data) || data.isBlocked is bool) &&
             (!('college' in data) || data.college is string);
    }

    function isValidMOA(data) {
      let validStatuses = [
        'Approved: Signed by President',
        'Approved: On-going notarization',
        'Approved: No notarization needed',
        'Processing: Awaiting signature of the MOA draft by HTE partner',
        'Processing: MOA draft sent to Legal Office for Review',
        'Processing: MOA draft and Opinion of Legal Office sent to VPPA/OP for approval',
        'Expired: No renewal done',
        'Expiring: Two months before expiration of date'
      ];
      let validIndustries = [
        'Government',
        'Private Sector',
        'Non-Profit Organization',
        'Educational Institution',
        'International Organization',
        'Others'
      ];
      return data.keys().hasAll(['HTEID', 'Company', 'Status', 'college']) &&
             data.Company is string && data.Company.size() > 0 && data.Company.size() < 200 &&
             data.Status in validStatuses &&
             data.IndustryType in validIndustries &&
             data.college is string &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('auditTrail' in data) || data.auditTrail is list);
    }

    function isValidActivity(data) {
      return data.keys().hasAll(['userId', 'action', 'timestamp']) &&
             data.userId is string &&
             data.action is string &&
             data.timestamp is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'timestamp', 'read']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string &&
             data.timestamp is string &&
             data.read is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'student' || isAdmin());
      allow update: if isAdmin() || 
                    (isOwner(userId) && 
                     isValidUser(request.resource.data) && 
                     request.resource.data.role == resource.data.role &&
                     request.resource.data.get('isBlocked', false) == resource.data.get('isBlocked', false));
    }

    match /moas/{moaId} {
      allow read: if isAuthenticated() && !isBlocked();
      allow create: if isFaculty() && !isBlocked() && isValidMOA(request.resource.data);
      allow update: if isFaculty() && !isBlocked() && isValidMOA(request.resource.data) &&
                    (isAdmin() || (resource.data.get('isDeleted', false) == false && request.resource.data.get('isDeleted', false) == false));
      allow delete: if false;
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && !isBlocked() && isValidActivity(request.resource.data) && request.resource.data.userId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAuthenticated() && !isBlocked() && isValidNotification(request.resource.data);
    }

    match /pre_authorized_roles/{email} {
      allow read: if isAuthenticated() && (request.auth.token.get('email', '') == email || isAdmin());
      allow write: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
